.env
.env.*.local
node_modules/
*.log
.DS_Store

# Cursor 로컬 캐시 등은 무시하되, 팀 공유 규칙(.cursor/rules)은 추적
.cursor/*
!.cursor/rules/
!.cursor/rules/**
.vscode/
# 로컬 supabase CLI 산출물은 무시하되, 레포에 포함하는 마이그레이션만 추적
supabase/*
!supabase/migrations/
!supabase/migrations/*.sql
.runtime/
tmp/
# Preflight 산출물(로컬/CI에서 생성; .gitkeep 만 추적)
ops/preflight_manifest/*.json
ops/preflight_ack/*.json
# 시나리오 하니스 산출물(로컬 실행물; .gitkeep 만 추적)
ops/scenario_runs/*.json
# W12-A live binding qualification 원장 (로컬/운영자 생성, raw secret 금지)
ops/live_binding_capability_qualifications.json
ops/rehearsal_eligibility.json

# --- Slack (필수) ---
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=

# --- OpenAI (필수) ---
OPENAI_API_KEY=
# 선택
OPENAI_MODEL=gpt-5.4

# --- GitHub — live: 토큰 + owner/repo 가 모두 있어야 함. 아래 두 스타일 중 하나(또는 혼합)면 됨.
#
# 방식 A (표준)
#   GITHUB_TOKEN + GITHUB_REPOSITORY=owner/repo
# 방식 B (기존 .env 호환)
#   GITHUB_FINE_GRAINED_PAT + GITHUB_DEFAULT_OWNER + GITHUB_DEFAULT_REPO
# 우선순위: 토큰은 GITHUB_TOKEN > GITHUB_FINE_GRAINED_PAT, 저장소는 GITHUB_REPOSITORY > OWNER/REPO 조합.
GITHUB_TOKEN=
GITHUB_REPOSITORY=G1ART/slack_cos
GITHUB_FINE_GRAINED_PAT=
GITHUB_DEFAULT_OWNER=G1ART
GITHUB_DEFAULT_REPO=slack_cos

# --- Supabase — apply_sql live: SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY + DB에 public.cos_apply_sql(sql_text) RPC (supabase/migrations 참고). 없으면 artifact.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Cursor — create_spec live: 실행 파일이 실제 존재(CURSOR_CLI_BIN 또는 PATH의 agent|cursor-agent) + CURSOR_PROJECT_DIR(또는 cwd)가 디렉터리. 없으면 artifact-only(emit_patch도 artifact).
CURSOR_CLI_BIN=agent
CURSOR_PROJECT_DIR=
# 선택: CLI 인자 오버라이드(비어 있으면 기본 create_spec + title)
# CURSOR_CREATE_SPEC_ARGS=
# CURSOR_CLI_TIMEOUT_MS=120000

# --- Railway — inspect_logs live: RAILWAY_TOKEN + deployment_id(payload 또는 RAILWAY_DEPLOYMENT_ID). deploy는 이 빌드에서 live 비활성 → 항상 artifact.
RAILWAY_TOKEN=
RAILWAY_DEPLOYMENT_ID=

# --- 런타임 상태 디렉터리 (선택) ---
# COS_RUNTIME_STATE_DIR=

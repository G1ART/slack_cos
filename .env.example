# --- Slack (필수) ---
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
# Socket Mode: 동일 SLACK_APP_TOKEN으로 프로세스를 두 개 이상 띄우면 이벤트가 나뉘고, 로컬 전용 경로/구버전 코드가 끼어든 것처럼 보일 수 있다. Railway 운영 중에는 로컬 node app.js 를 끄거나 별도 테스트 앱을 쓴다.
SLACK_APP_TOKEN=
# 선택: 채널 스레드 후속 처리 시 app_mention 과 message 중복 방지용. 비우면 첫 수신에서 auth.test 로 캐시.
# SLACK_BOT_USER_ID=Uxxxxxxxx
# 스레드 후속을 받으려면 Slack 앱 이벤트에 message.channels (및 필요 시 message.groups) 구독 필요.

# --- OpenAI (필수) ---
OPENAI_API_KEY=
# 선택
OPENAI_MODEL=gpt-5.4

# --- GitHub — live: 토큰 + owner/repo 가 모두 있어야 함. 아래 두 스타일 중 하나(또는 혼합)면 됨.
#
# 방식 A (표준)
#   GITHUB_TOKEN + GITHUB_REPOSITORY=owner/repo
# 방식 B (기존 .env 호환)
#   GITHUB_FINE_GRAINED_PAT + GITHUB_DEFAULT_OWNER + GITHUB_DEFAULT_REPO
# 우선순위: 토큰은 GITHUB_TOKEN > GITHUB_FINE_GRAINED_PAT, 저장소는 GITHUB_REPOSITORY > OWNER/REPO 조합.
GITHUB_TOKEN=
GITHUB_REPOSITORY=G1ART/slack_cos
GITHUB_FINE_GRAINED_PAT=
GITHUB_DEFAULT_OWNER=G1ART
GITHUB_DEFAULT_REPO=slack_cos

# --- Public ingress (Railway 등) — 프로세스는 기본적으로 PORT(또는 COS_HTTP_PORT, 기본 3000)에 0.0.0.0 바인딩. Slack은 Socket Mode 유지.
# Railway가 주입하는 PORT를 그대로 쓰면 public domain health check가 통과한다.
# PUBLIC_BASE_URL: 예) https://slackcos-production.up.railway.app (로그·문서용, 선택)
# GET /healthz, GET /readyz — JSON 헬스
# POST /webhooks/github | /webhooks/cursor | /webhooks/railway — GitHub/Cursor는 시크릿 있으면 본 처리·JSON 응답, 없으면 202 스켈레톤. 레거시 GitHub: POST /cos/webhooks/github (plain 응답)
# Cursor: 헤더 x-cursor-signature-256 값은 sha256=<hex> (HMAC-SHA256(raw body), 시크릿은 CURSOR_WEBHOOK_SECRET).
PUBLIC_BASE_URL=
GITHUB_WEBHOOK_SECRET=
CURSOR_WEBHOOK_SECRET=
# Cursor inbound webhook JSON dot-path (설정 시 휴리스틱보다 우선). 값은 로그에 넣지 말 것.
# CURSOR_WEBHOOK_RUN_ID_PATH=outer.run.id
# CURSOR_WEBHOOK_STATUS_PATH=outer.phase
# CURSOR_WEBHOOK_THREAD_KEY_PATH=context.threadKey
# CURSOR_WEBHOOK_PACKET_ID_PATH=context.packetId
# CURSOR_WEBHOOK_ACCEPTED_ID_PATH=data.backgroundComposerId
# CURSOR_WEBHOOK_BRANCH_PATH=data.branch
# CURSOR_WEBHOOK_PR_URL_PATH=data.pr.url
# CURSOR_WEBHOOK_SUMMARY_PATH=data.message
# CURSOR_WEBHOOK_OCCURRED_AT_PATH=meta.at
RAILWAY_WEBHOOK_SECRET=
# COS_HTTP_PORT=8080  # PORT 미설정 시 대체
# 수신 전체 끄기: COS_HTTP_DISABLED=1

# --- Supabase — apply_sql live: SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY + DB에 public.cos_apply_sql(sql_text) RPC (supabase/migrations 참고). 없으면 artifact.
# durable run state (cos_runs / cos_supervisor_leases): 키가 있으면 executionRunStore 가 Supabase 를 씀. 없으면 기본 file(JSON). 테스트는 COS_RUN_STORE=memory.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# scripts/summarize-ops-smoke-sessions.mjs 는 레포 루트 .env 를 자동 로드(dotenv).
# Ops smoke summary (vNext.13.43) read-only: 비우면 SUPABASE_* 사용. 로컬에서 프로덕션 DB만 볼 때 URL/키 분리용.
# COS_RUNTIME_SUPABASE_URL=
# COS_RUNTIME_SUPABASE_SERVICE_ROLE_KEY=
# COS_RUN_STORE=memory | file | (비우면 Supabase 키 있으면 supabase, 없으면 file)

# --- Cursor — cloud-first: CURSOR_CLOUD_AGENT_ENABLED=1 이고 아래 Automation(endpoint+auth)가 있으면 HTTP로 트리거 후 /webhooks/cursor 로 완료. 없으면 CLI, 둘 다 없으면 artifact.
# CURSOR_CLOUD_AGENT_ENABLED=1
# CURSOR_AUTOMATION_ENDPOINT=https://…  # Cursor Automation(또는 중계) POST URL — founder 응답에 넣지 말 것
# CURSOR_AUTOMATION_AUTH_HEADER=Bearer …   # 또는 "X-Custom-Header: value" 한 줄
# CURSOR_CLOUD_TIMEOUT_MS=60000
# 응답 JSON 필드가 중첩이면 dot-path로 지정(설정 시 휴리스틱보다 우선). 예: data.run.id
# CURSOR_AUTOMATION_RESPONSE_RUN_ID_PATH=data.run.id
# 권장(현행 Cursor 응답이 backgroundComposerId 중심일 때): 명시적으로 두는 것이 ops 진실에 유리
# CURSOR_AUTOMATION_RESPONSE_ACCEPTED_ID_PATH=backgroundComposerId
# CURSOR_AUTOMATION_RESPONSE_URL_PATH=data.run.url
# CURSOR_AUTOMATION_RESPONSE_STATUS_PATH=result.phase
# CURSOR_AUTOMATION_RESPONSE_BRANCH_PATH=result.ref
# 실제 엔드포인트 스모크(ledger·로그 중심, founder chatter 없음): CURSOR_AUTOMATION_SMOKE_MODE=1
#
# Ops-only real smoke evidence (vNext.13.42): cos_run_events.event_type=ops_smoke_phase, payload에 안전 부분집합만.
# raw body / 전체 URL / 시크릿 저장 안 함. Slack 명령어 추가 없음.
# COS_OPS_SMOKE_ENABLED=1
# COS_OPS_SMOKE_SESSION_ID=  # 비우면 프로세스당 자동 smoke_<ts>_<hex>
# COS_OPS_SMOKE_SESSION_ID_PREFIX=  # 선택: 멀티 제품·배포 시 자동 세션 ID 앞에 붙임(영숫자·-_만, 최대 32자). summarize --session-prefix 와 짝지음
# COS_PARCEL_DEPLOYMENT_KEY=  # 선택: 공유 Supabase에서 요약 이벤트 payload에 parcel_deployment_key 태그(스모크 요약·감사 스코프). 비우면 레거시 전역. summarize / audit 은 --parcel-deployment-key 로 덮어쓸 수 있음
# 요약 병합: 기본은 DB 뷰 cos_ops_smoke_summary_stream 한 번. 예전 이중 쿼리만 강제(임시 디버그)할 때만:
# COS_SMOKE_SUMMARY_LEGACY_MERGE_ONLY=1
# 운영 프로덕션에서는 비워 둘 것(뷰 적용 프로젝트 기준).
# trigger_accepted_callback_pending 이후 검증된 Cursor 직접 웹훅이 없을 때 슈퍼바이저가 기록하는 타임아웃(초). 기본 120.
# COS_CURSOR_CALLBACK_ABSENCE_TIMEOUT_SEC=120
#
# vNext.13.84 — narrow delegate emit_patch(live_only+no_fallback) 수락 뒤 GitHub secondary recovery envelope 를 등록하지 않음(완료 권위=프로바이더 콜백). 미설정 시 기존과 동일(등록함).
# COS_STRICT_LIVE_EMIT_PATCH_PROVIDER_ONLY=1
#
# Outbound callback contract (vNext.13.53): 트리거 POST 본문에 콜백 URL/시크릿 필드를 합성(로그·ops에는 path-only·필드명만).
# 켜려면 =1 이고, resolve된 콜백 URL + CURSOR_WEBHOOK_SECRET 이 모두 있어야 contract_present (describeTriggerCallbackContractForOps).
# 로컬 .env 는 git 에 포함되지 않음(.gitignore) — 운영·CI는 호스트 환경변수로 동일 키 주입.
# CURSOR_AUTOMATION_CALLBACK_CONTRACT_ENABLED=1
# CURSOR_AUTOMATION_CALLBACK_URL=   # 비우면 PUBLIC_BASE_URL + CURSOR_AUTOMATION_CALLBACK_PATH
# PUBLIC_BASE_URL=https://your-cos-host.example
# CURSOR_AUTOMATION_CALLBACK_PATH=/webhooks/cursor
# CURSOR_AUTOMATION_CALLBACK_URL_FIELD=callbackUrl
# CURSOR_AUTOMATION_CALLBACK_SECRET_FIELD=webhookSecret
# CURSOR_AUTOMATION_COMPLETION_POLICY_FIELD=execution_completion_policy
# CURSOR_AUTOMATION_SECONDARY_EFFECTS_FIELD=side_effects_are_non_primary
# CURSOR_AUTOMATION_COMPLETION_POLICY_NOTE_FIELD=cos_completion_policy_note
#
# vNext.13.69 — 수락 후 자연 콜백 대기 → 미도착 시 동일 호스트로 서명 합성 콜백 POST(어댑터 전용). 비우면 narrow emit_patch(live_only+no_fallback)만; 0=끔; 1=cursor 수락 전부.
# CURSOR_AUTOMATION_FORCE_CALLBACK_ON_PENDING=
# CURSOR_AUTOMATION_FORCE_CALLBACK_TIMEOUT_SEC=120
# CURSOR_AUTOMATION_FORCE_CALLBACK_MAX_ATTEMPTS=4
CURSOR_CLI_BIN=agent
CURSOR_PROJECT_DIR=
# 선택: CLI 인자 오버라이드(비어 있으면 기본 create_spec + title)
# CURSOR_CREATE_SPEC_ARGS=
# CURSOR_CLI_TIMEOUT_MS=120000

# --- Railway — inspect_logs live: RAILWAY_TOKEN + deployment_id(payload 또는 RAILWAY_DEPLOYMENT_ID). deploy는 이 빌드에서 live 비활성 → 항상 artifact.
RAILWAY_TOKEN=
RAILWAY_DEPLOYMENT_ID=

# --- 런타임 상태 디렉터리 (선택) ---
# COS_RUNTIME_STATE_DIR=

# --- 비동기 run 슈퍼바이저 (마일스톤 Slack 콜백) ---
# COS_RUN_SUPERVISOR_MS=45000
# 로컬/단일 프로세스만: COS_RUN_SUPERVISOR_DISABLED=1 로 끌 수 있음

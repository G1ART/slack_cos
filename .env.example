# 대표 호칭 — COS·Council·라우터 등 LLM 지시문에 주입 (기본 HENRY). 슬랙 표시명과 맞추면 됨.
# COS_EXECUTIVE_NAME=HENRY

# Slack (필수)
SLACK_BOT_TOKEN=xoxb-
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=xapp-

# OpenAI (필수)
OPENAI_API_KEY=

# 선택
OPENAI_MODEL=gpt-5.4

# 런타임: local | hosted (미설정 시 NODE_ENV=production 이면 hosted)
RUNTIME_MODE=local

# 저장소 (hosted 기본: dual + STORE_READ_PREFERENCE=supabase 는 코드 기본값)
# STORAGE_MODE=json | dual | supabase
# STORE_READ_PREFERENCE=json | supabase

# Supabase (RUNTIME_MODE=hosted 일 때 startup 에서 필수)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# 조회 응답: `tryFinalizeSlackQueryRoute` 가 Block Kit section(mrkdwn)으로 나눔. 끄면 평문만.
# SLACK_QUERY_BLOCKS=0
# 같은 PLN/WRK 로 이어지는 조회만 하단 버튼 (`g1cos_query_nav_*`). 끄기:
# SLACK_QUERY_NAV_BUTTONS=0

# dialog 응답 하단의 워크스페이스 큐 확인 버튼(실행 큐 / 고객 피드백 / 안 올림). 끄기:
# SLACK_DIALOG_QUEUE_BUTTONS=0

# 스레드/DM 대화 버퍼를 `data/slack-conversation-buffer.json` 에 주기적으로 저장 (재시작 후 transcript 복구).
# CONVERSATION_BUFFER_PERSIST=true
# 경로 오버라이드: CONVERSATION_BUFFER_FILE=/path/to/buffer.json
# 끄기(기본): CONVERSATION_BUFFER_PERSIST 미설정 또는 false

# 로컬·스테이징: `툴제작:` 등 start_project 한 메시지에서 실행큐 적재 후 PLN·WRK까지 바로 승격(운영 prod에서는 끔 권장).
# COS_FAST_SPEC_PROMOTE=1
# Founder DM/멘션: 자연어를 패킷 없이 GPT 직답 (기본 on). 끄려면 0.
# 창업자 DM/멘션: 기본은 자연어 단일 경로(runCosNaturalPartner). COS_FOUNDER_DIRECT_CHAT=0 이면 골드/페이즈 헌법 파이프라인(테스트·비상).
# COS_FOUNDER_DIRECT_CHAT=0

# 창업자: JSON 구조화 플래너(callJSON)로 sidecar·실행 아티팩트 힌트 생성. 기본 끔 — 슬랙 대화는 COS 단일 LLM 1회만(이중 모델·Council 성향 완화).
# 아티팩트 게이트·구조화 실행이 필요한 운영만 1 로 켠다.
# COS_FOUNDER_STRUCTURED_PLANNER=1

# vNext.13.12 — 창업자 durable state 기본 파일은 repo 밖 (미설정 시 OS tmp 아래 g1cos-runtime).
# COS_RUNTIME_STATE_DIR=/path/to/runtime
# FOUNDER_CONVERSATION_STATE_FILE=/path/to/founder-conversation-state.json

# Founder DM preflight: 기본은 staging trace on. 끄려면 0 (founder_staging_mode 등 trace 표식 비활성).
# COS_FOUNDER_STAGING_MODE=0

# Founder DM/멘션 Slack 파일 인테이크 (DOCX·PDF 텍스트·PNG vision). 기본 최대 15MB.
# COS_FOUNDER_FILE_MAX_BYTES=15728640
# durable_state.latest_file_contexts 최대 보관 개수 (기본 10)
# COS_FOUNDER_FILE_CONTEXT_CAP=10
# PNG vision 모델 (기본 gpt-4o-mini)
# COS_FOUNDER_IMAGE_MODEL=gpt-4o-mini

# 외부 에이전트 런타임(하네스/워커) URL — 커서발행·이슈발행·수파베이스발행 성공 시 JSON POST (비우면 전송 안 함)
# COS_AGENT_BRIDGE_URL=https://your-worker.example/hooks/cos
# COS_AGENT_BRIDGE_SECRET=shared-secret
# COS_BRIDGE_INSTANCE_ID=prod-a

# Cursor Cloud / 자동화 — outbound 시 run 메타를 JSON POST (없으면 handoff-only manual_bridge)
# COS_CURSOR_CLOUD_LAUNCH_URL=https://your-automation.example/cursor-launch
# COS_CURSOR_CLOUD_LAUNCH_SECRET=
# COS_CURSOR_CLOUD_DISABLE=1

# Supabase — 스키마 드래프트·마이그레이션 스텁은 항상 로컬 생성 가능. 원격 적용은 웹훅으로만(옵션).
# COS_SUPABASE_LIVE_DISPATCH_URL=https://your-worker.example/supabase-dispatch
# COS_SUPABASE_LIVE_DISPATCH_SECRET=
# COS_SUPABASE_LIVE_DISABLE=1
